{
	"name": "p1_csv_files_ingestion",
	"properties": {
		"activities": [
			{
				"name": "ADLS Files names",
				"type": "GetMetadata",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_all_files_names",
						"type": "DatasetReference"
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"recursive": true,
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "Iterate childs",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "ADLS Files names",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('ADLS Files names').output.childItems",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "Copy file to bronze",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "DelimitedTextSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "DelimitedTextReadSettings"
									}
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".txt"
									}
								},
								"enableStaging": false,
								"translator": {
									"value": "@if(\r\n    contains(item().name, 'performance'), \r\n    pipeline().parameters.performance_schema, \r\n    if(\r\n        contains(item().name, 'campaign'), \r\n        pipeline().parameters.campaign_schema, \r\n        null\r\n    )\r\n)",
									"type": "Expression"
								}
							},
							"inputs": [
								{
									"referenceName": "ds_adls_allfiles_source",
									"type": "DatasetReference",
									"parameters": {
										"p_filename": {
											"value": "@item().name",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_csvfiles_to_bronze_dest",
									"type": "DatasetReference",
									"parameters": {
										"p_folder_name": {
											"value": "@if(\n    contains(item().name, 'performance'), \n    'social_post_performance', \n    if(\n        contains(item().name, 'campaign'), \n        'campaign_lookup',\n        'unclassified_data'\n    )\n)",
											"type": "Expression"
										},
										"p_filename": {
											"value": "@if(\n    contains(item().name, 'performance'), \n    concat('social_post_performance_', formatDateTime(utcNow(), 'yyyyMMdd_HHmmss'), '_', item().name), \n    if(\n        contains(item().name, 'campaign'), \n        concat('campaign_lookup_', formatDateTime(utcNow(), 'yyyyMMdd_HHmmss'), '_', item().name),\n        concat('unclassified_', item().name)\n    )\n)",
											"type": "Expression"
										}
									}
								}
							]
						},
						{
							"name": "Delete file after ingestion",
							"type": "Delete",
							"dependsOn": [
								{
									"activity": "Copy file to bronze",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "ds_adls_allfiles_source",
									"type": "DatasetReference",
									"parameters": {
										"p_filename": "@item().name"
									}
								},
								"logStorageSettings": {
									"linkedServiceName": {
										"referenceName": "ls_adls_connection",
										"type": "LinkedServiceReference"
									},
									"path": "load/deletelogs"
								},
								"enableLogging": true,
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								}
							}
						}
					]
				}
			}
		],
		"parameters": {
			"campaign_schema": {
				"type": "object",
				"defaultValue": {
					"type": "TabularTranslator",
					"mappings": [
						{
							"source": {
								"name": "campaign_id",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "campaign_id",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "campaign_name",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "campaign_name",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "client_id",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "client_id",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "budget_usd",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "budget_usd",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "start_date",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "start_date",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "end_date",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "end_date",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "goal",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "goal",
								"type": "String",
								"physicalType": "String"
							}
						}
					],
					"typeConversion": true,
					"typeConversionSettings": {
						"allowDataTruncation": true,
						"treatBooleanAsNumber": false
					}
				}
			},
			"performance_schema": {
				"type": "object",
				"defaultValue": {
					"type": "TabularTranslator",
					"mappings": [
						{
							"source": {
								"name": "post_id",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "post_id",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "campaign_id",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "campaign_id",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "platform",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "platform",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "post_date",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "post_date",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "impressions",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "impressions",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "reach",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "reach",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "clicks",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "clicks",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "shares",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "shares",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "content_type",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "content_type",
								"type": "String",
								"physicalType": "String"
							}
						},
						{
							"source": {
								"name": "posted_ts",
								"type": "String",
								"physicalType": "String"
							},
							"sink": {
								"name": "posted_ts",
								"type": "String",
								"physicalType": "String"
							}
						}
					],
					"typeConversion": true,
					"typeConversionSettings": {
						"allowDataTruncation": true,
						"treatBooleanAsNumber": false
					}
				}
			}
		},
		"annotations": []
	}
}