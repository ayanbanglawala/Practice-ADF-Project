{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfprojectayan"
		},
		"ls_adls_connection_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_connection'"
		},
		"ls_sql_connection_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_connection'"
		},
		"ls_adls_connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageprojectayan.dfs.core.windows.net/"
		},
		"ls_api_connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://mocki.io"
		},
		"ls_sql_connection_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverayan.database.windows.net"
		},
		"ls_sql_connection_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldbayan"
		},
		"ls_sql_connection_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ayan"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfprojectayan_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_connection_accountKey": {
						"value": "[parameters('ls_adls_connection_accountKey')]"
					},
					"ls_sql_connection_password": {
						"value": "[parameters('ls_sql_connection_password')]"
					},
					"ls_adls_connection_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_connection_properties_typeProperties_url')]"
					},
					"ls_api_connection_properties_typeProperties_url": {
						"value": "[parameters('ls_api_connection_properties_typeProperties_url')]"
					},
					"ls_sql_connection_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_connection_properties_typeProperties_server')]"
					},
					"ls_sql_connection_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_connection_properties_typeProperties_database')]"
					},
					"ls_sql_connection_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_connection_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adfprojectayan_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adfprojectayan_ArmTemplate_0')]"
			]
		}
	]
}