{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfprojectayan"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/p1_csv_files_ingestion')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "ADLS Files names",
						"type": "GetMetadata",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"dataset": {
								"referenceName": "ds_all_files_names",
								"type": "DatasetReference",
								"parameters": {}
							},
							"fieldList": [
								"childItems"
							],
							"storeSettings": {
								"type": "AzureBlobFSReadSettings",
								"recursive": true,
								"enablePartitionDiscovery": false
							},
							"formatSettings": {
								"type": "DelimitedTextReadSettings"
							}
						}
					},
					{
						"name": "Iterate childs",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "ADLS Files names",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('ADLS Files names').output.childItems",
								"type": "Expression"
							},
							"activities": [
								{
									"name": "Copy file to bronze",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "DelimitedTextSource",
											"storeSettings": {
												"type": "AzureBlobFSReadSettings",
												"recursive": true,
												"enablePartitionDiscovery": false
											},
											"formatSettings": {
												"type": "DelimitedTextReadSettings"
											}
										},
										"sink": {
											"type": "DelimitedTextSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "DelimitedTextWriteSettings",
												"quoteAllText": true,
												"fileExtension": ".txt"
											}
										},
										"enableStaging": false,
										"translator": {
											"value": "@if(\r\n    contains(item().name, 'performance'), \r\n    pipeline().parameters.performance_schema, \r\n    if(\r\n        contains(item().name, 'campaign'), \r\n        pipeline().parameters.campaign_schema, \r\n        null\r\n    )\r\n)",
											"type": "Expression"
										}
									},
									"inputs": [
										{
											"referenceName": "ds_adls_allfiles_source",
											"type": "DatasetReference",
											"parameters": {
												"p_filename": {
													"value": "@item().name",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_csvfiles_to_bronze_dest",
											"type": "DatasetReference",
											"parameters": {
												"p_folder_name": {
													"value": "@if(\n    contains(item().name, 'performance'), \n    'social_post_performance', \n    if(\n        contains(item().name, 'campaign'), \n        'campaign_lookup',\n        'unclassified_data'\n    )\n)",
													"type": "Expression"
												},
												"p_filename": {
													"value": "@if(\n    contains(item().name, 'performance'), \n    concat('social_post_performance_', formatDateTime(utcNow(), 'yyyyMMdd_HHmmss'), '_', item().name), \n    if(\n        contains(item().name, 'campaign'), \n        concat('campaign_lookup_', formatDateTime(utcNow(), 'yyyyMMdd_HHmmss'), '_', item().name),\n        concat('unclassified_', item().name)\n    )\n)",
													"type": "Expression"
												}
											}
										}
									]
								},
								{
									"name": "Delete file after ingestion",
									"type": "Delete",
									"dependsOn": [
										{
											"activity": "Copy file to bronze",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"dataset": {
											"referenceName": "ds_adls_allfiles_source",
											"type": "DatasetReference",
											"parameters": {
												"p_filename": "@item().name"
											}
										},
										"logStorageSettings": {
											"linkedServiceName": {
												"referenceName": "ls_adls_connection",
												"type": "LinkedServiceReference"
											},
											"path": "load/deletelogs"
										},
										"enableLogging": true,
										"storeSettings": {
											"type": "AzureBlobFSReadSettings",
											"recursive": true,
											"enablePartitionDiscovery": false
										}
									}
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"parameters": {
					"campaign_schema": {
						"type": "object",
						"defaultValue": {
							"type": "TabularTranslator",
							"mappings": [
								{
									"source": {
										"name": "campaign_id",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "campaign_id",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "campaign_name",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "campaign_name",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "client_id",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "client_id",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "budget_usd",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "budget_usd",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "start_date",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "start_date",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "end_date",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "end_date",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "goal",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "goal",
										"type": "String",
										"physicalType": "String"
									}
								}
							],
							"typeConversion": true,
							"typeConversionSettings": {
								"allowDataTruncation": true,
								"treatBooleanAsNumber": false
							}
						}
					},
					"performance_schema": {
						"type": "object",
						"defaultValue": {
							"type": "TabularTranslator",
							"mappings": [
								{
									"source": {
										"name": "post_id",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "post_id",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "campaign_id",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "campaign_id",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "platform",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "platform",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "post_date",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "post_date",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "impressions",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "impressions",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "reach",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "reach",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "clicks",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "clicks",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "shares",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "shares",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "content_type",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "content_type",
										"type": "String",
										"physicalType": "String"
									}
								},
								{
									"source": {
										"name": "posted_ts",
										"type": "String",
										"physicalType": "String"
									},
									"sink": {
										"name": "posted_ts",
										"type": "String",
										"physicalType": "String"
									}
								}
							],
							"typeConversion": true,
							"typeConversionSettings": {
								"allowDataTruncation": true,
								"treatBooleanAsNumber": false
							}
						}
					}
				},
				"annotations": []
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/p2_api_data_ingestion')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "Until hasMore",
						"type": "Until",
						"dependsOn": [],
						"userProperties": [],
						"typeProperties": {
							"expression": {
								"value": "@equals(variables('hasMore'), false)",
								"type": "Expression"
							},
							"activities": [
								{
									"name": "Copy API Data",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "JsonSource",
											"storeSettings": {
												"type": "HttpReadSettings",
												"requestMethod": "GET"
											},
											"formatSettings": {
												"type": "JsonReadSettings"
											}
										},
										"sink": {
											"type": "JsonSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "JsonWriteSettings"
											}
										},
										"enableStaging": false
									},
									"inputs": [
										{
											"referenceName": "ds_api_source",
											"type": "DatasetReference",
											"parameters": {}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_api_to_adls_dest",
											"type": "DatasetReference",
											"parameters": {}
										}
									]
								},
								{
									"name": "API validate",
									"type": "WebActivity",
									"dependsOn": [
										{
											"activity": "Copy API Data",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"method": "GET",
										"headers": {},
										"url": "https://mocki.io/v1/410bc703-7c36-4382-9ba1-1d8e6a33f2ff"
									}
								},
								{
									"name": "If hasMore",
									"type": "IfCondition",
									"dependsOn": [
										{
											"activity": "API validate",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"userProperties": [],
									"typeProperties": {
										"expression": {
											"value": "@activity('API validate').output.has_more",
											"type": "Expression"
										},
										"ifFalseActivities": [
											{
												"name": "Set hasMore",
												"type": "SetVariable",
												"dependsOn": [],
												"policy": {
													"secureOutput": false,
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"variableName": "hasMore",
													"value": false
												}
											}
										]
									}
								}
							],
							"timeout": "0.12:00:00"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"variables": {
					"hasMore": {
						"type": "Boolean",
						"defaultValue": true
					}
				},
				"annotations": []
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/Dataflow')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_read_performance_csvs",
								"type": "DatasetReference"
							},
							"name": "performance"
						},
						{
							"dataset": {
								"referenceName": "ds_read_api_jsons",
								"type": "DatasetReference"
							},
							"name": "apiresponse"
						},
						{
							"dataset": {
								"referenceName": "ds_read_campaign_csvs",
								"type": "DatasetReference"
							},
							"name": "Campaign"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "Performance_parquet",
								"type": "DatasetReference"
							},
							"name": "sinkToADLS"
						},
						{
							"dataset": {
								"referenceName": "Engagement_parquet",
								"type": "DatasetReference"
							},
							"name": "sinkAPIToADLS"
						},
						{
							"dataset": {
								"referenceName": "Campaign_Parquet",
								"type": "DatasetReference"
							},
							"name": "sinkCampaign"
						}
					],
					"transformations": [
						{
							"name": "flattenArrays"
						},
						{
							"name": "filterdate"
						},
						{
							"name": "derivedcolupper"
						},
						{
							"name": "aggregatededuplication"
						},
						{
							"name": "derivedColumns"
						},
						{
							"name": "aggregate"
						},
						{
							"name": "DerivedCampaign"
						},
						{
							"name": "aggregateCampaign"
						}
					],
					"scriptLines": [
						"source(output(",
						"          post_id as string,",
						"          campaign_id as string,",
						"          platform as string,",
						"          post_date as date,",
						"          impressions as long,",
						"          reach as long,",
						"          clicks as long,",
						"          shares as long,",
						"          content_type as string,",
						"          posted_ts as timestamp",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     wildcardPaths:['csvfiles/social_post_performance/*.csv']) ~> performance",
						"source(output(",
						"          since_id as string,",
						"          next_since_id as string,",
						"          has_more as boolean,",
						"          data as (engagement_id as string, post_id as string, user_id as string, engagement_type as string, reaction_type as string, engagement_ts as string, sentiment_score as double, influencer_flag as boolean)[]",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     documentForm: 'singleDocument',",
						"     wildcardPaths:['/api_responses/*.json']) ~> apiresponse",
						"source(output(",
						"          campaign_id as string,",
						"          campaign_name as string,",
						"          client_id as string,",
						"          budget_usd as double,",
						"          start_date as date,",
						"          end_date as date,",
						"          goal as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     wildcardPaths:['csvfiles/campaign_lookup/*.csv']) ~> Campaign",
						"apiresponse foldDown(unroll(data, data),",
						"     mapColumn(",
						"          engagement_id = data.engagement_id,",
						"          engagement_ts = data.engagement_ts,",
						"          engagement_type = data.engagement_type,",
						"          influencer_flag = data.influencer_flag,",
						"          post_id = data.post_id,",
						"          reaction_type = data.reaction_type,",
						"          sentiment_score = data.sentiment_score,",
						"          user_id = data.user_id",
						"     ),",
						"     skipDuplicateMapInputs: false,",
						"     skipDuplicateMapOutputs: false) ~> flattenArrays",
						"performance filter(post_date <= currentDate() && !isNull(reach)) ~> filterdate",
						"filterdate derive(platform = iif(isNull(platform), 'UNAVAILABLE',upper(platform)),",
						"          clicks = iif(isNull(clicks), 0, toInteger(iif(clicks > impressions, impressions, clicks))),",
						"          reach = iif(isNull(reach), 0, toInteger(reach)),",
						"          campaign_id = iif(isNull(campaign_id), 'UNAVAILABLE', campaign_id)) ~> derivedcolupper",
						"derivedcolupper aggregate(groupBy(post_id),",
						"     campaign_id = last(campaign_id),",
						"          platform = last(platform),",
						"          post_date = last(post_date),",
						"          impressions = last(impressions),",
						"          reach = last(reach),",
						"          clicks = last(clicks),",
						"          shares = last(shares),",
						"          content_type = last(content_type),",
						"          posted_ts = last(posted_ts)) ~> aggregatededuplication",
						"flattenArrays derive(engagement_type = upper(engagement_type),",
						"          sentiment_score = iif(sentiment_score > 1.0 || sentiment_score < -1.0 || isNull(sentiment_score), toDecimal(0), toDecimal(sentiment_score)),",
						"          reaction_type = coalesce(reaction_type, 'NONE'),",
						"          user_id = coalesce(user_id, 'UNKNOWN')) ~> derivedColumns",
						"derivedColumns aggregate(groupBy(engagement_id),",
						"     engagement_ts = last(engagement_ts),",
						"          engagement_type = last(engagement_type),",
						"          influencer_flag = last(influencer_flag),",
						"          post_id = last(post_id),",
						"          reaction_type = last(reaction_type),",
						"          sentiment_score = last(sentiment_score),",
						"          user_id = last(user_id)) ~> aggregate",
						"Campaign derive(budget_usd = coalesce(toDecimal(budget_usd), 0.0),",
						"          client_id = coalesce(client_id, 'UNKNOWN'),",
						"          campaign_name = trim(campaign_name)) ~> DerivedCampaign",
						"DerivedCampaign aggregate(groupBy(campaign_id),",
						"     campaign_name = last(campaign_name),",
						"          budget_usd = last(budget_usd),",
						"          start_date = last(start_date),",
						"          end_date = last(end_date),",
						"          goal = last(goal)) ~> aggregateCampaign",
						"aggregatededuplication sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     format: 'parquet',",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sinkToADLS",
						"aggregate sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     format: 'parquet',",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sinkAPIToADLS",
						"aggregateCampaign sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     format: 'parquet',",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sinkCampaign"
